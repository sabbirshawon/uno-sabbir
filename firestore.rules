rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /unoRooms/{roomId} {
      // Public room state has no private hands or private deck.
      allow read: if request.auth != null;

      // All writes are done by Next.js API routes through Firebase Admin SDK.
      allow create, update, delete: if false;

      match /hands/{userId} {
        // Each player can only read their own private hand.
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /private/{docId} {
        // Hidden draw pile/discard history. Server only.
        allow read, write: if false;
      }

      match /chat/{messageId} {
        // Authenticated users can listen to chat. Sending goes through server route.
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
  }
}
